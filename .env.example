# Copy to .env and source it, or export these vars in your shell.
# obcd-pilot does not auto-load .env.

# YOLOv8 weights path. If missing, ultralytics tries a network download.
OBCD_YOLO_WEIGHTS=yolov8n.pt

# OBCD checkpoint directory. Overrides the default (<cwd>/weights, falling
# back to the Qt per-user app data location).
OBCD_WEIGHTS_DIR=weights
